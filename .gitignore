# Env / secrets
.env
.env.*
!.env.example
*.pem

# Java / Maven
target/
*.class

# Python (core: MCP server + indexer)
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/
.pytest_cache/
.ruff_cache/

# IDE / OS
.idea/
*.iml
.vscode/
.DS_Store

# Logs / scratch
logs/
*.log
# Cygwin/MSYS crash dumps — a grep abort on this platform drops one in the repo root.
*.stackdump

# Stray LLM notes from a dev enrich run against this repo (real targets commit these — Layer 1).
.code-context/

# DB backups (db-backup writes daily dumps here; keep the dir, ignore the dumps)
infra/backups/*
!infra/backups/.gitkeep

# Raw local capture (notes/README.md explains the flow). Gitignored on purpose: capture has to be
# frictionless enough to name real systems, and this repo is public. Only the scrubbed form, in
# plans/INBOX.md, is committed.
notes/*
!notes/README.md

# Local denylist for tools/agent-skills/scripts/check-private-terms.* (scrub-identity).
# A committed denylist names exactly what it hides — never track this file.
.private-terms
